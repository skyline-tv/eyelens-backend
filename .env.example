PORT=5001
MONGO_URI=
JWT_SECRET=
JWT_EXPIRES_IN=
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=
# Comma-separated browser origins allowed for cookies/CORS (store + admin dev defaults below).
CLIENT_URLS=http://localhost:3000,http://localhost:3001
CLIENT_URL=
# Absolute API base for uploaded file URLs (defaults to request Host). Use when behind a proxy.
PUBLIC_BASE_URL=
# Storefront base URL for email links (defaults to first CLIENT_URLS entry)
STOREFRONT_URL=
NODE_ENV=

# Optional — npm run seed:admin
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_NAME=

# Optional — npm run seed:customer
# SEED_CUSTOMER_EMAIL=
# SEED_CUSTOMER_PASSWORD=
# SEED_CUSTOMER_NAME=

# Razorpay — online checkout (COD works without these)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Return / admin notifications (defaults to SMTP_USER if unset)
ADMIN_EMAIL=

# Email (nodemailer) — leave unset to skip sending mail
# Resend SMTP example:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxx
# SMTP_FROM=Eyelens <noreply@yourdomain.com>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cloudinary — image upload for admin
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
